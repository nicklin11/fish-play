function play
    set -l platform "sc" # Default platform is SoundCloud
    set -l proxy_on 0
    set -l query_args

    # 1. Manually parse arguments so flags can be placed anywhere
    for arg in $argv
        switch "$arg"
            case "-yt"
                set platform "yt"
            case "-rt"
                set platform "rt"
            case "-vk"
                set platform "vk"
            case "-sc"
                set platform "sc"
            case "-ya"
                set platform "ya"
            case "-proxy_on"
                set proxy_on 1
            case "*"
                # If it's not a flag, it's part of your search text / URL
                set -a query_args "$arg"
        end
    end

    # Join the remaining strings into our search query
    set -l input (string join " " $query_args)

    if test -z "$input"
        echo "Usage: play[-yt|-rt|-vk|-sc|-ya] [-proxy_on] <query or url>"
        return 1
    end

    set -l log_file /tmp/mpv-music.log
    set -l bg_flags --no-video --no-terminal --input-ipc-server=/tmp/mpvsocket --ytdl-format=bestaudio
    set -l proxy_url "socks5://127.0.0.1:2080"

    # 2. Configure MPV/FFmpeg Proxy securely
    if test $proxy_on -eq 1
        # mpv's internal ytdl hook needs the proxy
        set -a bg_flags --ytdl-raw-options="yes-playlist=,proxy=$proxy_url"
    else
        set -a bg_flags --ytdl-raw-options="yes-playlist="
    end

    # Create an mpv launch wrapper. If proxy is on, we inject SOCKS5 environment variables 
    # directly into FFmpeg (which mpv uses to stream the audio).
    set -l launch_mpv mpv $bg_flags
    if test $proxy_on -eq 1
        set launch_mpv env all_proxy="$proxy_url" http_proxy="$proxy_url" https_proxy="$proxy_url" mpv $bg_flags
    end

    # 3. Direct URL bypass (Skip text-searching if you pasted a direct link)
    if string match -r "^https?://" "$input" > /dev/null
        notify-send -a "Music" "🎶 Starting Stream..." "Loading URL..."
        $launch_mpv "$input" >/dev/null 2>&1 &
        disown
        return 0
    end

    # 4. Text Searching Logic
    notify-send -a "Music" "🔍 Searching..." "Platform: $platform | Query: $input"

    # Set up yt-dlp extractor base command
    set -l ytdl_cmd yt-dlp
    if test $proxy_on -eq 1
        set -a ytdl_cmd --proxy "$proxy_url"
    end

    # Handle YouTube exclusively (Keeps your Infinite Mix Trick)
    if test "$platform" = "yt"
        set -l search_arg "ytsearch1:$input"
        set -l video_id ($ytdl_cmd --get-id --no-playlist "$search_arg" 2>/dev/null | head -n 1)

        if test -n "$video_id"
            set -l mix_url "https://www.youtube.com/watch?v=$video_id&list=RD$video_id"
            $launch_mpv "$mix_url" >/dev/null 2>&1 &
            disown
            notify-send -a "Music" "✅ YouTube Mix Started" "Based on $video_id"
        else
            notify-send -a "Music" "❌ No results found" "YouTube search failed."
        end
        return 0
    end

    # Handle other platforms (Extract Top 1 Result)
    set -l search_query ""
    switch "$platform"
        case "sc"; set search_query "scsearch1:$input"
        case "vk"; set search_query "vksearch1:$input"
        case "rt"; set search_query "rutubesearch1:$input"
        case "ya"; set search_query "yandexmusicsearch1:$input"
    end

    # Ask yt-dlp to print exactly two lines: The Title, and the Webpage URL
    set -l result ($ytdl_cmd --print "%(title)s" --print "%(webpage_url)s" --no-playlist "$search_query" 2>/dev/null)

    if test (count $result) -ge 2
        set -l track_title $result[1]
        set -l track_url $result[2]

        $launch_mpv "$track_url" >/dev/null 2>&1 &
        disown
        notify-send -a "Music" "✅ Jam Started ($platform)" "$track_title"
    else
        notify-send -a "Music" "❌ No results found" "Could not extract search from $platform"
        echo "yt-dlp failed to resolve: $search_query"
    end
end